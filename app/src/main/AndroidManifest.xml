<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Saaapps">

        <!-- BaseActivity sebagai LAUNCHER (SEMENTARA UNTUK TESTING) -->
        <activity
            android:name=".BaseActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SplashScreenActivity -->
        <activity
            android:name=".SplashScreenActivity"
            android:exported="false"
            android:theme="@style/Theme.Saaapps" />

        <!-- Login Activity -->
        <activity
            android:name=".pertemuan4.AuthActivity"
            android:exported="false" />

        <!-- Main Activity (sudah tidak digunakan) -->
        <activity
            android:name=".pertemuan4.MainActivity"
            android:exported="false" />

        <!-- Pertemuan 4 - Activity Lainnya -->
        <activity
            android:name=".pertemuan4.RumusBangunRuangActivity"
            android:exported="false" />
        <activity
            android:name=".pertemuan4.Custom1Activity"
            android:exported="false" />
        <activity
            android:name=".pertemuan4.Custom2Activity"
            android:exported="false" />
        <activity
            android:name=".pertemuan4.FourthActivity"
            android:exported="false" />

    </application>

</manifest>