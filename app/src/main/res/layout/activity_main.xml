<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EEF4FF">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#223187"
        android:title="Dashboard"
        android:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Greeting Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat Datang"
                        android:textSize="14sp"
                        android:textColor="#64748B" />

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halo, User"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#223187"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRumusBangunRuang"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:text="Rumus Bangun Ruang"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:backgroundTint="#223187"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCustom1"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:text="Custom 1"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:backgroundTint="#3949AB"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCustom2"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:text="Custom 2"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:backgroundTint="#5C6BC0"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToFourth"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:text="Fourth Activity"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:backgroundTint="#1E40AF"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenWebsite"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:text="Web View"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:backgroundTint="#2563EB"
                        app:cornerRadius="18dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="Logout"
                android:textColor="#EF4444"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>