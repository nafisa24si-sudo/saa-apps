<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2E7D32"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Selamat Datang -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selamat Datang"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Halo, admin"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Tombol Rumus Bangun Ruang -->
            <Button
                android:id="@+id/btnRumusBangunRuang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rumus Bangun Ruang"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button" />

            <!-- Tombol Custom 1 -->
            <Button
                android:id="@+id/btnCustom1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Custom 1"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button" />

            <!-- Tombol Custom 2 -->
            <Button
                android:id="@+id/btnCustom2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Custom 2"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button" />

            <!-- Tombol Fourth Activity -->
            <Button
                android:id="@+id/btnFourthActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fourth Activity"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button" />

            <!-- Tombol Web View -->
            <Button
                android:id="@+id/btnWebView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Web View"
                android:layout_marginBottom="24dp"
                style="@style/Widget.Material3.Button" />

            <!-- Tombol Logout -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:backgroundTint="#D32F2F"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>