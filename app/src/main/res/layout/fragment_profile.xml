<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2E7D32"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Avatar -->
            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/ic_profile"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <!-- Nama -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama: [Nama Lengkap Anda]"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- NIM -->
            <TextView
                android:id="@+id/tvNim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NIM: [NIM Anda]"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Kelas -->
            <TextView
                android:id="@+id/tvClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kelas: [Kelas Anda]"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Deskripsi -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📱 Tentang Pengembang"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Halo! Saya adalah pengembang aplikasi Bina Desa ini. Aplikasi ini dibuat untuk membantu pendataan dan pemantauan program pembangunan desa di wilayah binaan."
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:padding="12dp"
                android:background="#E8F5E9" />

            <!-- Kontak -->
            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📧 Email: [email Anda]"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>