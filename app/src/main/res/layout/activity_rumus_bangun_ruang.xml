<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvJudul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Rumus Bangun Ruang"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#1E293B"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvDeskripsi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Pelajari volume bangun ruang dengan mudah di sini."
            android:textSize="15sp"
            android:textColor="#64748B"
            app:layout_constraintTop_toBottomOf="@id/tvJudul"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tvDeskripsi">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Volume"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#3B82F6"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#3B82F6"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Kubus: V = s³\n\n• Balok: V = p × l × t\n\n• Bola: V = 4/3 × π × r³"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="8dp"
                    android:textColor="#334155" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tips: Pastikan satuan panjang seragam."
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="#94A3B8"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardMath"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:text="Kembali"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:backgroundTint="#1E293B"
            app:layout_constraintTop_toBottomOf="@id/tvHint" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>